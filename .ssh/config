# ~/.ssh/config — managed in ~/dotfiles via stow.
# Private / machine-specific hosts go in ~/.ssh/config.local (untracked).
#
# ssh applies the FIRST value seen for each option, so this Include is at the top:
# anything in config.local wins over the global defaults below.
Include ~/.ssh/config.local

# ── Global defaults (apply to every host) ─────────────────────────────────────
Host *
  # Load the key into the agent on first use and cache its passphrase in the
  # macOS Keychain. Result: `git` commit signing and `ssh` never re-prompt,
  # even in a fresh terminal after a reboot.
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes          # offer only the key(s) above, not every agent key

  # Connection hygiene / resilience
  ServerAliveInterval 60
  ServerAliveCountMax 3
  TCPKeepAlive yes
  Compression yes
  HashKnownHosts yes

  # Reuse a single connection for repeated sessions to the same host (faster
  # git fetch/push). Needs ~/.ssh/control to exist (setup_zsh.sh creates it).
  ControlMaster auto
  ControlPath ~/.ssh/control/%C
  ControlPersist 10m

# ── GitHub ────────────────────────────────────────────────────────────────────
Host github.com
  HostName github.com
  User git
  PreferredAuthentications publickey
  IdentityFile ~/.ssh/id_ed25519

# ── GitLab ────────────────────────────────────────────────────────────────────
Host gitlab.com
  HostName gitlab.com
  User git
  PreferredAuthentications publickey
  IdentityFile ~/.ssh/id_ed25519
