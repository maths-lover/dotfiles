# Stow ignore-list ‚Äî only ~/dotfiles/.config should be symlinked into $HOME.
# NOTE: a custom .stow-local-ignore REPLACES stow's built-in defaults, so the
# usual VCS/junk patterns are re-listed here.
#
# Patterns containing "/" are anchored to the repo root; bare patterns match any
# path segment.

# ‚îÄ‚îÄ repo metadata (never link into $HOME) ‚îÄ‚îÄ
^/install\.sh$
^/README\.md$
^/LICENSE$
^/\.git$
^/\.gitignore$
^/\.gitmodules$
^/\.github$
^/\.stow-local-ignore$

# ‚îÄ‚îÄ editor / OS junk (anywhere) ‚îÄ‚îÄ
\.DS_Store
.+~
\#.*\#
