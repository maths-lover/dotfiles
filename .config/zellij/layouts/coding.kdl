// coding layout - a project environment (the Kitty-sessions equivalent).
// Left: editor (nvim, opens cwd via oil). Right column: a shell over lazygit.
// Launched by the `zj` session switcher; panes inherit the project directory.
layout {
    // Slim single-line bar at the top (session / tabs / mode), matching the
    // compact default and nvim's single statusline.
    pane size=1 borderless=true {
        plugin location="zellij:compact-bar"
    }
    pane split_direction="vertical" {
        pane size="72%" {
            command "nvim"
            args "."
            focus true
            close_on_exit true
        }
        pane size="28%" split_direction="horizontal" {
            pane name="shell"
            pane name="git" {
                command "lazygit"
                close_on_exit true
            }
        }
    }
}
